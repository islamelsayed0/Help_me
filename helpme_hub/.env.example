# Django core
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app,*.railway.app,your-custom-domain.com
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app,https://your-custom-domain.com

# Database (Railway PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# Optional Railway fallback split variables
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Recommended production security flags
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Optional: email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Optional: OAuth + AI
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1000
GEMINI_TEMPERATURE=0.7

# Optional: Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_PRICE_ID_AI_ADDON=

# Optional: monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
